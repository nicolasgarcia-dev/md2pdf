# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2
LOG_LEVEL=info

# Maximum markdown payload size in bytes (default: 1 MiB)
MAX_MARKDOWN_BYTES=1048576
# Maximum uploaded file size in bytes (default: 2 MiB)
MAX_UPLOAD_BYTES=2097152

# Rate limiting (per client IP)
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=200

# Owner bypass token.
# Leave empty to disable. If set, requests carrying this token in the
# X-Bypass-Token header (or the bypass cookie) skip rate limits and
# use the higher OWNER_MAX_* size limits.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BYPASS_TOKEN=
OWNER_MAX_MARKDOWN_BYTES=20971520
OWNER_MAX_UPLOAD_BYTES=52428800

# Trusted proxy header for real client IP when behind Nginx Proxy Manager.
# Set to "true" only when the app is reachable exclusively through NPM.
TRUST_PROXY_HEADERS=true

# CORS allowlist (comma-separated origins). Leave empty for same-origin only.
CORS_ALLOW_ORIGINS=
